# Supabase (bắt buộc để đồng bộ cloud)
# Lấy tại: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Bỏ trống 2 biến trên để chạy offline (chỉ dùng localStorage)

# Claude AI API backend (cho Chat AI, Story Generator, Writing AI)
# Để trống để chạy local không có AI
VITE_API_URL=https://game.somail.us
# Khi dev local: VITE_API_URL=http://localhost:3001
